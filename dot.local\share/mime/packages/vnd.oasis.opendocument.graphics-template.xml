<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info"> 
  <mime-type type="application/vnd.oasis.opendocument.graphics-template">
    <comment>OpenDocument Drawing Template</comment>
    <comment xml:lang="sv">OpenDocument teckningsmall</comment>
    <glob pattern="*.otg"/>
    <generic-icon name="application-vnd.oasis.opendocument.graphics-template.svg"/>  
    <magic priority="60">
        <match value="PK\003\004" type="string" offset="0">
            <match value="mimetype" type="string" offset="30">
                <match value="application/vnd.oasis.opendocument.graphics-template" type="string" offset="38"/>
            </match>
        </match>
    </magic>
  </mime-type>
</mime-info>